{% sw_extends '@Storefront/storefront/component/checkout/offcanvas-cart-summary.html.twig' %}

{% block component_offcanvas_summary_content %}
    <style>
        .offcanvas-cart-grand-total { display: none !important; }
    </style>
    <div class="offcanvas-summary" style="font-size:85%">
        {% block component_offcanvas_summary_total %}
            {% set surchargeAmount = 0 %}
            {% if page.cart and page.cart.lineItems %}
                {% for lineItem in page.cart.lineItems %}
                    {% if lineItem.type == 'surcharge' %}
                        {% set surchargeAmount = surchargeAmount + lineItem.price.totalPrice %}
                    {% endif %}
                {% endfor %}
            {% endif %}
            {% set productSubtotal = page.cart.price.positionPrice - surchargeAmount %}

            <div class="row g-0 py-1">
                <div class="col-7">{{ 'checkout.summaryPositionPrice'|trans|sw_sanitize }}</div>
                <div class="col-5 text-end"><strong>{{ productSubtotal|currency }}</strong></div>
            </div>

            {% if surchargeAmount > 0 %}
                {% for lineItem in page.cart.lineItems %}
                    {% if lineItem.type == 'surcharge' %}
                        <div class="row g-0 py-1">
                            <div class="col-7">{{ lineItem.label }}</div>
                            <div class="col-5 text-end">{{ lineItem.price.totalPrice|currency }}</div>
                        </div>
                    {% endif %}
                {% endfor %}
            {% endif %}

            {% if page.cart.deliveries is defined %}
                {% for activeShipping in page.cart.deliveries.elements %}
                    <div class="row g-0 py-1">
                        <div class="col-7">{{ 'checkout.summaryShipping'|trans|sw_sanitize }}
                            {% if loop.first and page.shippingMethods|length %}
                                <button class="btn btn-sm btn-link js-toggle-shipping-selection">
                                    ({{ activeShipping.shippingMethod.translated.name }})
                                </button>
                            {% endif %}
                        </div>
                        <div class="col-5 text-end">
                            {% set shippingTotalPrice = activeShipping.shippingCosts.totalPrice ?? 0 %}
                            <strong>{{ shippingTotalPrice < 0 ? '&minus;' : '+' }} {{ shippingTotalPrice|abs|currency }}</strong>
                        </div>
                    </div>
                {% endfor %}

                {% if page.cart.price.taxStatus == 'free' %}
                    <div class="row g-0 py-1">
                        <div class="col-7">{{ 'checkout.summaryTotalPrice'|trans|sw_sanitize }}</div>
                        <div class="col-5 text-end"><strong>{{ page.cart.price.totalPrice|currency }}</strong></div>
                    </div>
                {% else %}
                    {% if page.cart.price.taxStatus == 'net' %}
                        <div class="row g-0 py-1">
                            <div class="col-7">{{ 'checkout.summaryNetPrice'|trans|sw_sanitize }}</div>
                            <div class="col-5 text-end">{{ page.cart.price.netPrice|currency }}</div>
                        </div>
                    {% endif %}
                    {% for calculatedTax in page.cart.price.calculatedTaxes %}
                        <div class="row g-0 py-1">
                            <div class="col-7">
                                {% if page.cart.price.taxStatus == 'gross' %}
                                    {{ 'checkout.summaryTaxInclude'|trans({'%rate%': calculatedTax.taxRate})|sw_sanitize }}
                                {% else %}
                                    {{ 'checkout.summaryTax'|trans({'%rate%': calculatedTax.taxRate})|sw_sanitize }}
                                {% endif %}
                            </div>
                            <div class="col-5 text-end">{{ calculatedTax.tax|currency }}</div>
                        </div>
                    {% endfor %}
                    <div class="row g-0 py-1">
                        <div class="col-7"><strong>{{ 'checkout.summaryTotalPrice'|trans|sw_sanitize }}</strong></div>
                        <div class="col-5 text-end"><strong>{{ page.cart.price.totalPrice|currency }}</strong></div>
                    </div>
                {% endif %}
            {% endif %}
        {% endblock %}
    </div>
{% endblock %}

{% block component_offcanvas_summary_content_info %}{% endblock %}

{% block component_offcanvas_summary_tax_info %}{% endblock %}
