<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/System/SystemConfig/Schema/config.xsd">

    <card>
        <title>Aufschlag Einstellungen</title>
        <title lang="en-GB">Surcharge Settings</title>

        <!-- Feld für den Aufschlag in Prozent -->
        <input-field type="float">
            <name>surchargePercentage</name>
            <label>Aufschlag in Prozent (%)</label>
            <label lang="en-GB">Surcharge in percent (%)</label>
            <defaultValue>3.9</defaultValue>
            <helpText>Gib den prozentualen Aufschlag ein (z.B. 3.9)</helpText>
        </input-field>

        <!-- Feld für den Namen im Warenkorb -->
        <input-field type="text">
            <name>surchargeName</name>
            <label>Name des Aufschlags (Warenkorb)</label>
            <label lang="en-GB">Surcharge Name (Cart)</label>
            <defaultValue>Service-Aufschlag</defaultValue>
            <helpText>Dieser Name wird dem Kunden im Warenkorb und auf der Rechnung angezeigt.</helpText>
        </input-field>

        <!-- Optional: Ein/Ausschalter -->
        <input-field type="bool">
            <name>isActive</name>
            <label>Aufschlag aktivieren</label>
            <label lang="en-GB">Activate surcharge</label>
            <defaultValue>true</defaultValue>
        </input-field>
    </card>

    <card>
        <title>Rundungseinstellungen</title>
        <title lang="en-GB">Rounding Settings</title>

        <input-field type="bool">
            <name>enableRappenRundung</name>
            <label>Auf 0.05 CHF runden (Rappenrundung)</label>
            <label lang="en-GB">Round to 0.05 CHF (Swiss rappen rounding)</label>
            <defaultValue>false</defaultValue>
            <helpText>Aktiviert die Rappenrundung des Aufschlags auf 0.05 CHF (für die Schweiz).</helpText>
            <helpText lang="en-GB">Enables rounding of the surcharge to 0.05 CHF (for Switzerland).</helpText>
        </input-field>
    </card>

    <card>
        <title>Steuer</title>
        <title lang="en-GB">Tax</title>

        <component name="sw-entity-single-select">
            <name>taxId</name>
            <entity>tax</entity>
            <label>Steuersatz für den Aufschlag</label>
            <label lang="en-GB">Tax rate for surcharge</label>
            <helpText>Wähle den Steuersatz aus der Datenbank, der auf den Aufschlag angewendet werden soll (z.B. 8.1% oder 2.6%).</helpText>
            <helpText lang="en-GB">Select the tax rate from the database to apply to the surcharge (e.g. 8.1% or 2.6%).</helpText>
        </component>
    </card>
</config>