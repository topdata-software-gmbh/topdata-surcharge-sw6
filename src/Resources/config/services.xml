<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Topdata\TopdataSurchargeSW6\Core\Checkout\Cart\SurchargeCartProcessor">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="tax.repository"/>
            <argument type="service" id="translator"/>
            <tag name="shopware.cart.processor" priority="4500" />
        </service>

        <service id="Topdata\TopdataSurchargeSW6\Subscriber\MailSurchargeSubscriber">
            <argument type="service" id="order_line_item.repository"/>
            <tag name="kernel.event_subscriber"/>
        </service>
    </services>
</container>